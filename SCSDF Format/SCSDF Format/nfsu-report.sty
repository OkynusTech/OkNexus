% ---------- Declaration page style (ONLY when you call it) ----------
\fancypagestyle{nfsuCertificate}{
	\fancyhf{}
	\renewcommand{\headrulewidth}{0pt}
	\fancyhead[L]{\includegraphics[height=1.6cm]{\NFSUEmblemFile}}
}

% ---------- Helpers: header/footer lines + watermark ONLY for one page ----------
\newcommand{\NFSUHeaderRule}{%
	\noindent{\color{NFSUSkyBlue}\rule{\textwidth}{1.5pt}}\par\vspace{1cm}
}

\newcommand{\NFSUFooterRule}{%
	\vspace{1cm}\noindent{\color{NFSUSkyBlue}\rule{\textwidth}{1.5pt}}\par
	\vspace{2mm}
	\noindent
	 \noindent\hfill{\color{NFSUGray} \textbf{\thepage}\,\textbar\,P\;a\;g\;e}\par
}

% --- normal pages header ---
\fancypagestyle{NFSUPageHFStyle}{
	\fancyhf{} % clear
	
	% header row text
	\fancyhead[L]{\color{NFSUGray}\StudentName}
	\fancyhead[R]{\color{NFSUGray}\EnrollmentNo}
	% blue rule below header
	\renewcommand{\headrulewidth}{1.5pt}
	\renewcommand{\headrule}{%
		\hbox to\headwidth{%
			\color{NFSUSkyBlue}\leaders\hrule height \headrulewidth\hfill
		}%
	}

	% (optional) footer page label like your screenshot
	\fancyfoot[R]{%
		{
			\noindent{\color{NFSUSkyBlue}\rule{\textwidth}{1.5pt}}\par
			\vspace{2mm}
			\noindent
			\noindent\hfill{\color{NFSUGray} \textbf{\thepage}\,\textbar\,P\;a\;g\;e}\par
		}%
	}
	\renewcommand{\footrulewidth}{0pt}
}

\newcommand{\NFSUWatermarkOn}{%
	\AddToShipoutPictureBG{%
		\AtPageCenter{%
			\raisebox{-0.10\paperheight}{%
				\makebox[0pt][c]{%
					\transparent{0.10}%
					\includegraphics[width=0.35\paperwidth]{\NFSULogoFile}%
				}%
			}%
		}%
	}%
}
\newcommand{\NFSUWatermarkOff}{\ClearShipoutPictureBG}



% ---------- Title page command (ready-made) ----------
\newcommand{\MakeTitlePage}{%
	{
	\clearpage
	\thispagestyle{empty}
	\centering
	\shadowoffset{0.6pt}
	\parindent=0pt
	\parskip=8pt
	{\large
		\textit{\color{NFSUDarkRed}A \ReportType \space on} \par
		\textbf{\shadowtext{\color{NFSUDarkRed}\MakeTextUppercase{\ProjectTitle}}} \par
		\textit{\color{NFSUDarkBlue}Submitted in partial fulfillment for the Degree of} \par
		\textbf{\color{NFSUDarkRed}\MakeTextUppercase{\ProgramName}} \\
	}	
	
	\vspace{1cm}
	
	{\large\textit{\color{NFSUDarkRed}Submitted by}} \par
	{\large \textbf{\color{NFSUDarkBlue}\MakeTextUppercase{\Honorific.\StudentName}}} \par
	{\textbf{\color{NFSUDarkBlue}(\EnrollmentNo)}}
	
	\vspace{1cm}
	
	{\large\textit{\color{NFSUDarkRed}Under The Supervision of}} \par
	{\large \textbf{\color{NFSUDarkBlue}\MakeTextUppercase{\SupervisorName}}} \par
	{\textbf{\color{NFSUDarkBlue}(\SupervisorDesig)}}
	
	\vspace{1cm}
	{\large\textit{\color{NFSUDarkRed}Submitted to}} \par
	\includegraphics[width=4cm]{\NFSULogoFile} \\ \par
	
	\vspace{1cm}
	{\large \textbf{\color{NFSUDarkRed}\MakeTextUppercase{\NFSUSchool}}} \par  
	{\large \textbf{\color{NFSUDarkRed}NATIONAL FORENSIC SCIENCES UNIVERSITY}} \par
	{\large \textbf{\color{NFSUDarkRed}{\MakeTextUppercase{\CampusLocation -\CampusPin, \CampusState, \CampusCountry}.}}} \par
	{\large \textbf{\color{NFSUDarkRed}\ReportMonthYear}\\\vfill}
	%{\Large \textbf{\color{NFSUDarkRed}\ReportMonthYear\\\vfill}
	}
	\clearpage
}


% ---------- Declaration page command (ready-made) ----------
\newcommand{\MakeDeclarationPage}{%
	\clearpage
	\thispagestyle{nfsuCertificate}
	\NFSUAddToTOC{Declaration By Student}
	\NFSUHeaderRule
	\NFSUWatermarkOn
	\begin{center}
		\textbf{\large DECLARATION BY STUDENT}
	\end{center}
	\vspace{1cm}
	\textit{I hereby declare that the work being presented in this Report titled \textbf{\ProjectTitle} by me i.e. \textbf{\StudentName}, having Enrolment Number \textbf{\EnrollmentNo}, and submitted to the \NFSUSchool at National Forensic Sciences University, \CampusLocation; is my original work carried out during the period of \textbf{\ReportPeriodFrom} to \textbf{\ReportPeriodTo} under the supervision of \textbf{\SupervisorName}. I have complied it with the School’s Ethical Code of Conduct and have duly acknowledged all sources through proper citations and references. The plagiarism check confirms that the overall similarity index is within 10\%.}
	\vspace{2cm}
	
	\noindent\rule{6cm}{0.4pt}\\
	(\textbf{\StudentName})
	\vfill
	\NFSUFooterRule
	\clearpage
}

% ---------- Guide Certificate page command (ready-made) ----------

