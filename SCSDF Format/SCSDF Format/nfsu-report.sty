% --------- Heading styles (Chapter/Section/Subsection/Subsubsection) ---------
\setcounter{secnumdepth}{3}
\setcounter{tocdepth}{3}

% CHAPTER: 2.  SPECIFICATIONS FOR ...
% CHAPTER formatting
\RequirePackage{titlesec}
% Make chapter starting pages also use our fancy header/footer
\RequirePackage{etoolbox}
\patchcmd{\chapter}{\thispagestyle{plain}}{\thispagestyle{NFSUPageHFStyle}}{}{}
% -------- Chapter Style --------
\titleformat{\chapter}[block]
{\centering\bfseries\Large\color{NFSUSkyBlue}}
{\thechapter.\hspace{0.6em}}
{0pt}
{\MakeTextUppercase}
\titlespacing*{\chapter}{0pt}{0.5cm}{0.6cm}

% SECTION: 2.1  Preparation ...
\titleformat{\section}[hang]
{\bfseries\color{NFSUSkyBlue}\normalsize}
{\thesection\hspace{1.2em}}
{0pt}
{}
\titlespacing*{\section}{0pt}{0.8em}{0.4em}

% SUBSECTION: 2.2  Size and Margins
\titleformat{\subsection}[hang]
{\bfseries\color{NFSUSkyBlue}\normalsize}
{\thesubsection\hspace{1.2em}}
{0pt}
{}
\titlespacing*{\subsection}{0pt}{0.7em}{0.35em}

% SUBSUBSECTION: 2.2.1  Printing of Dissertation
\titleformat{\subsubsection}[hang]
{\bfseries\color{NFSUSkyBlue}\normalsize}
{\thesubsubsection\hspace{1.2em}}
{0pt}
{}
\titlespacing*{\subsubsection}{0pt}{0.6em}{0.25em}

% --------- Only-number subsubsection line like "2.2.2" (no title) ----------
\newcommand{\NFSUSubSubNumber}{%
	\refstepcounter{subsubsection}%
	\vspace{0.3em}%
	{\bfseries\color{NFSUSkyBlue}\thesubsubsection}\par
	\vspace{0.2em}%
}